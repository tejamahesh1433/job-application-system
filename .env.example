# Environment Variables - Copy to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================
# LLM API KEYS (Required)
# ============================================
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/job_application_system
DATABASE_ECHO=False
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ============================================
# Redis Configuration (for caching)
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# Google APIs (Gmail, Calendar)
# ============================================
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxx
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
GMAIL_ADDRESS=your-email@gmail.com

# ============================================
# Crunchbase API
# ============================================
CRUNCHBASE_API_KEY=xxxxxxxxxxxx

# ============================================
# Ollama Configuration (Local LLM)
# ============================================
OLLAMA_BASE_URL=http://localhost:11434
# Best model priority (auto-selected from what you have installed):
#   llama3.1:8b  →  ollama pull llama3.1:8b   (recommended, best for JSON)
#   mistral      →  ollama pull mistral         (good alternative)
#   qwen2.5:7b   →  ollama pull qwen2.5:7b      (fast, lightweight)
OLLAMA_MODEL=llama3.1:8b
USE_OLLAMA_FOR_SIMPLE_TASKS=True
FORCE_LOCAL_LLM=False

# ============================================
# System Configuration
# ============================================
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# FastAPI Settings
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# ============================================
# Application Settings
# ============================================
APPLICATIONS_PER_DAY=25
TIME_PER_APPLICATION_SECONDS=96
BATCH_SIZE=5
RETRY_ATTEMPTS=3
RETRY_DELAY=5

# Form Filling Settings
MIN_TYPING_DELAY_MS=50
MAX_TYPING_DELAY_MS=150
MIN_CLICK_DELAY_MS=100
MAX_CLICK_DELAY_MS=500

# ============================================
# Feature Flags
# ============================================
ENABLE_BROWSER_AUTOMATION=True
ENABLE_AUTO_SUBMIT=False  # Only enable in Phase 3
ENABLE_GMAIL_MONITORING=False  # Only enable in Phase 3
ENABLE_ANSWER_MEMORY=False  # Enable in Phase 2

# ============================================
# File Paths
# ============================================
UPLOADS_DIR=uploads/
APPLICATIONS_DIR=applications/
TRACKING_DIR=tracking/
RESUMES_DIR=resumes/
SCREENSHOTS_DIR=screenshots/
LOGS_DIR=logs/
CREDENTIALS_DIR=credentials/

# ============================================
# Proxy (optional)
# ============================================
PROXY_URL=
USE_PROXY=False

# ============================================
# Sentry (Error Tracking - optional)
# ============================================
SENTRY_DSN=
